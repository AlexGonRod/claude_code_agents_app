---
import Layout from '../layouts/layout.astro';
import ImageInput from '../components/ImageInput.svelte';
import ImagePreview from '../components/ImagePreview.svelte';
import InvoiceForm from '../components/InvoiceForm.svelte';
import Auth from '../components/Auth.svelte';
import SaveButton from '../components/SaveButton.svelte';
import { appState } from '../stores/app.js';

let imageData = null;
let invoiceData = {};
let isProcessing = false;
let isVerifying = false;
let error = null;
let success = null;

// Subscribe to app state updates
appState.subscribe(($appState) => {
    imageData = $appState.currentImage;
    invoiceData = $appState.invoiceData;
    isProcessing = $appState.isProcessing;
    isVerifying = $appState.isVerifying;
    error = $appState.error;
    success = $appState.success;
});

// Handle image selection from ImageInput component
function handleImageSelected(event) {
    // Update app state with selected image
    appState.update(state => ({
        ...state,
        currentImage: event.detail,
        isProcessing: true,
        error: null
    }));

    // Simulate OCR processing
    simulateOCRProcessing();
}

// Simulate OCR processing (in real app, this would be an API call)
async function simulateOCRProcessing() {
    try {
        // Simulate API delay
        await new Promise(resolve => setTimeout(resolve, 2000));

        // Mock OCR response - in real app, this would come from backend OCR endpoint
        const mockInvoiceData = {
            vendor: "ABC Store",
            date: "2026-04-20",
            amount: 45.67,
            tax: 3.65,
            line_items: [
                { description: "Product A", quantity: 2, unit_price: 10.00, amount: 20.00 },
                { description: "Product B", quantity: 1, unit_price: 15.00, amount: 15.00 },
                { description: "Product C", quantity: 3, unit_price: 3.56, amount: 10.67 }
            ],
            notes: "Purchase from ABC Store on April 20, 2026"
        };

        // Update app state with OCR results
        appState.update(state => ({
            ...state,
            invoiceData: mockInvoiceData,
            isProcessing: false,
            isVerifying: true
        }));
    } catch (err) {
        console.error('OCR processing error:', err);
        appState.update(state => ({
            ...state,
            error: 'Failed to process image. Please try again.',
            isProcessing: false
        }));
    }
}

// Handle updated invoice data from InvoiceForm component
function handleInvoiceUpdated(event) {
    appState.update(state => ({
        ...state,
        invoiceData: event.detail
    }));
}

// Handle save invoice from SaveButton component
async function handleSaveInvoice(event) {
    const dataToSave = event.detail;

    // Update app state to show saving
    appState.update(state => ({
        ...state,
        error: null,
        success: null
    }));

    try {
        // In a real app, we would send this to the backend save endpoint
        // For now, we'll simulate the save operation
        await new Promise(resolve => setTimeout(resolve, 1500));

        // Update app state with success
        appState.update(state => ({
            ...state,
            success: 'Invoice saved successfully to Google Drive!',
            // Reset form after successful save
            currentImage: null,
            invoiceData: {},
            isVerifying: false
        }));
    } catch (err) {
        console.error('Save error:', err);
        appState.update(state => ({
            ...state,
            error: 'Failed to save invoice. Please try again.'
        }));
    }
}
---

<Layout>
  <div class="page-container">
    <div class="auth-section">
      <Auth />
    </div>

    {#if !$appState.isAuthenticated}
      <div class="input-section">
        <h2>Capture Invoice</h2>
        <p>Take a photo of your invoice or select an existing image</p>
        <ImageInput on:image-selected={handleImageSelected} />
      </div>
    {/if}

    {#if $appState.isAuthenticated && !$appState.currentImage && !$appState.isProcessing && !$appState.isVerifying}
      <div class="input-section">
        <h2>Capture Invoice</h2>
        <p>Take a photo of your invoice or select an existing image</p>
        <ImageInput on:image-selected={handleImageSelected} />
      </div>
    {/if}

    {#if $appState.isProcessing}
      <div class="processing-section">
        <h2>Processing Invoice</h2>
        <p>Extracting information from your invoice...</p>
        <div class="loading-spinner">
          <div class="spinner"></div>
        </div>
      </div>
    {/if}

    {#if $appState.isVerifying && $appState.invoiceData}
      <div class="verification-section">
        <h2>Verify Invoice Information</h2>
        <p>Please review the extracted data and make any necessary corrections:</p>
        <ImagePreview
          imageSrc={$appState.currentImage?.imageData}
          loading={false}
          error={null}
        />
        <InvoiceForm
          invoiceData={$appState.invoiceData}
          loading={false}
          error={error}
          on:invoice-updated={handleInvoiceUpdated}
        />
        <SaveButton
          on:save-invoice={handleSaveInvoice}
        />
      </div>
    {/if}

    {#if $appState.error}
      <div class="error-message">
        {$appState.error}
      </div>
    {/if}

    {#if $appState.success}
      <div class="success-message">
        {$appState.success}
      </div>
    {/if}
  </div>
</Layout>

<style>
  .page-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 1rem;
  }

  .auth-section,
  .input-section,
  .processing-section,
  .verification-section {
    margin-bottom: 2rem;
  }

  h2 {
    color: #333;
    margin-bottom: 1rem;
  }

  p {
    color: #666;
    margin-bottom: 1.5rem;
  }

  .loading-spinner {
    display: flex;
    justify-content: center;
    margin: 2rem 0;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #f3f3f3;
    border-top: 4px solid #007bff;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .error-message {
    background-color: #f8d7da;
    color: #721c24;
    padding: 1rem;
    border-radius: 4px;
    margin: 1rem 0;
  }

  .success-message {
    background-color: #d4edda;
    color: #155724;
    padding: 1rem;
    border-radius: 4px;
    margin: 1rem 0;
  }

  /* Responsive adjustments */
  @media (max-width: 480px) {
    .page-container {
      padding: 0.5rem;
    }

    h2 {
      font-size: 1.25rem;
    }
  }
</style>