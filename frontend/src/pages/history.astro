---
import Layout from '../layouts/layout.astro';

let invoices = [
  {
    id: 1,
    vendor: "ABC Store",
    date: "2026-04-20",
    amount: 45.67,
    status: "saved"
  },
  {
    id: 2,
    vendor: "XYZ Restaurant",
    date: "2026-04-18",
    amount: 28.50,
    status: "saved"
  }
];
---

<Layout>
  <div class="page-container">
    <h1>Invoice History</h1>

    {#if invoices.length === 0}
      <div class="empty-state">
        <p>No invoices found. Start capturing invoices to see them here.</p>
      </div>
    {:else}
      <div class="invoice-list">
        {#each invoices as invoice}
          <div class="invoice-card">
            <div class="invoice-header">
              <h3>{invoice.vendor}</h3>
              <span class="status {invoice.status}">{invoice.status}</span>
            </div>
            <div class="invoice-details">
              <p><strong>Date:</strong> {invoice.date}</p>
              <p><strong>Amount:</strong> ${invoice.amount.toFixed(2)}</p>
            </div>
          </div>
        {/each}
      </div>
    {/if}
  </div>
</Layout>

<style>
  .page-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 1rem;
  }

  h1 {
    color: #333;
    text-align: center;
    margin-bottom: 2rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: #666;
  }

  .invoice-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .invoice-card {
    background-color: white;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    padding: 1.5rem;
  }

  .invoice-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .invoice-header h3 {
    margin: 0;
    color: #333;
  }

  .status {
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .status.saved {
    background-color: #d4edda;
    color: #155724;
  }

  .status.processing {
    background-color: #fff3cd;
    color: #856404;
  }

  .status.error {
    background-color: #f8d7da;
    color: #721c24;
  }

  .invoice-details p {
    margin: 0.5rem 0;
    color: #666;
  }

  /* Responsive adjustments */
  @media (max-width: 480px) {
    .page-container {
      padding: 0.5rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    .invoice-card {
      padding: 1rem;
    }
  }
</style>