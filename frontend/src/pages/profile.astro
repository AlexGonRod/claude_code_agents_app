---
import Layout from '../layouts/layout.astro';

let user = {
  name: 'John Doe',
  email: 'john.doe@example.com',
  photo: 'https://via.placeholder.com/150'
};
---

<Layout>
  <div class="page-container">
    <h1>Profile</h1>

    <div class="profile-card">
      <div class="profile-header">
        <img src={user.photo} alt="User Profile" class="profile-photo" />
        <h2>{user.name}</h2>
        <p class="profile-email">{user.email}</p>
      </div>

      <div class="profile-info">
        <div class="info-item">
          <h3>Account Information</h3>
          <p><strong>Email:</strong> {user.email}</p>
          <p><strong>Member since:</strong> April 2026</p>
          <p><strong>Total invoices saved:</strong> 12</p>
        </div>

        <div class="info-item">
          <h3>Preferences</h3>
          <p><strong>Default currency:</strong> USD</p>
          <p><strong>Date format:</strong> MM/DD/YYYY</p>
          <p><strong>Notifications:</strong> Enabled</p>
        </div>

        <div class="info-item">
          <h3>Security</h3>
          <p><strong>Last login:</strong> Today, 10:30 AM</p>
          <p><strong>Two-factor authentication:</strong> Disabled</p>
          <button class="btn-logout">Logout</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 1rem;
  }

  h1 {
    color: #333;
    text-align: center;
    margin-bottom: 2rem;
  }

  .profile-card {
    background-color: white;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    overflow: hidden;
  }

  .profile-header {
    text-align: center;
    padding: 2rem;
    background-color: #007bff;
    color: white;
  }

  .profile-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid white;
    margin-bottom: 1.5rem;
  }

  .profile-header h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.75rem;
  }

  .profile-email {
    margin: 0;
    opacity: 0.9;
    font-size: 1rem;
  }

  .profile-info {
    padding: 2rem;
  }

  .info-item {
    margin-bottom: 2rem;
  }

  .info-item h3 {
    color: #333;
    margin-bottom: 1rem;
    font-size: 1.25rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 0.5rem;
  }

  .info-item p {
    margin: 0.75rem 0;
    color: #666;
    line-height: 1.5;
  }

  .btn-logout {
    background-color: #dc3545;
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
    width: 100%;
    margin-top: 1.5rem;
    transition: background-color 0.2s;
  }

  .btn-logout:hover {
    background-color: #c82333;
  }

  /* Responsive adjustments */
  @media (max-width: 480px) {
    .page-container {
      padding: 0.5rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    .profile-header {
      padding: 1.5rem;
    }

    .profile-photo {
      width: 100px;
      height: 100px;
    }

    .profile-header h2 {
      font-size: 1.5rem;
    }

    .profile-info {
      padding: 1.5rem;
    }
  }
</style>