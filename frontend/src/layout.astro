---
const title = 'FACTURES';
import './styles/global.css';
import Toast from './components/Toast.svelte';
import Auth from './components/Auth.svelte';
import Nav from './components/Nav.svelte';

const currentPath = Astro.url.pathname;
const showAuth = currentPath !== '/profile';
---

<!DOCTYPE html>
<html lang="ca">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FDF8F5" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-surface text-primary font-display">
    <div class="min-h-screen flex flex-col bg-surface">
      <Toast client:load />
      <header class="bg-surface-2 border-b border-border sticky top-0 z-50">
        <div class="flex items-center justify-between w-full px-4 py-2">
          <h1 class="font-mono text-sm font-semibold text-accent-main tracking-widest">{title}</h1>
          {showAuth && <Auth client:load />}
        </div>
      </header>

      <main class="flex-1 px-4 pb-20 w-full max-w-[500px] mx-auto">
        <slot />
      </main>

      <Nav client:load />
    </div>

    <style is:global>
      @media (min-width: 768px) {
        nav {
          position: static;
          height: auto;
          border-top: none;
          border-bottom: 1px solid #333;
        }
        nav ul {
          flex-direction: row;
          max-width: 300px;
          margin: 0 auto;
        }
        nav a {
          flex-direction: row;
          gap: 0.5rem;
        }
      }
    </style>
  </body>
</html>